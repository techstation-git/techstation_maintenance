[
  {
    "doctype": "Custom HTML Block",
    "name": "Maintenance Operations Dashboard",
    "html": "<style>\n    .ms-dash {\n        font-family: sans-serif;\n        padding: 20px;\n        background: #f4f5f7;\n    }\n\n    .ms-dash h2 {\n        font-size: 18px;\n        font-weight: 700;\n        color: #1a1f36;\n        margin: 0 0 16px;\n        display: flex;\n        align-items: center;\n        gap: 8px;\n    }\n\n    .ms-dot {\n        width: 9px;\n        height: 9px;\n        border-radius: 50%;\n        background: #4ade80;\n        display: inline-block;\n        animation: msPulse 2s infinite;\n    }\n\n    @keyframes msPulse {\n\n        0%,\n        100% {\n            opacity: 1\n        }\n\n        50% {\n            opacity: .3\n        }\n    }\n\n    .ms-rbtn {\n        background: #fff;\n        border: 1px solid #e2e8f0;\n        border-radius: 6px;\n        padding: 4px 10px;\n        font-size: 12px;\n        cursor: pointer;\n        color: #64748b;\n        margin-left: 8px;\n    }\n\n    .ms-rbtn:hover {\n        background: #f1f5f9\n    }\n\n    .ms-cards {\n        display: grid;\n        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));\n        gap: 12px;\n        margin-bottom: 20px;\n    }\n\n    .ms-card {\n        background: #fff;\n        border-radius: 12px;\n        padding: 16px;\n        box-shadow: 0 1px 4px rgba(0, 0, 0, .07);\n        border-left: 4px solid #e2e8f0;\n        cursor: pointer;\n        transition: transform .15s;\n    }\n\n    .ms-card:hover {\n        transform: translateY(-2px);\n    }\n\n    .ms-card.blue {\n        border-left-color: #3b82f6\n    }\n\n    .ms-card.orange {\n        border-left-color: #f97316\n    }\n\n    .ms-card.green {\n        border-left-color: #22c55e\n    }\n\n    .ms-card.purple {\n        border-left-color: #a855f7\n    }\n\n    .ms-card.red {\n        border-left-color: #ef4444\n    }\n\n    .ms-clabel {\n        font-size: 11px;\n        font-weight: 600;\n        color: #64748b;\n        text-transform: uppercase;\n        margin-bottom: 4px;\n    }\n\n    .ms-cvalue {\n        font-size: 32px;\n        font-weight: 700;\n        color: #1a1f36;\n    }\n\n    .ms-csub {\n        font-size: 11px;\n        color: #94a3b8;\n        margin-top: 4px;\n    }\n\n    .ms-stitle {\n        font-size: 13px;\n        font-weight: 600;\n        color: #1a1f36;\n        border-bottom: 1px solid #e2e8f0;\n        padding-bottom: 6px;\n        margin: 0 0 10px;\n    }\n\n    .ms-sgrid {\n        display: grid;\n        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));\n        gap: 10px;\n        margin-bottom: 20px;\n    }\n\n    .ms-sitem {\n        background: #fff;\n        border-radius: 10px;\n        padding: 12px 14px;\n        box-shadow: 0 1px 3px rgba(0, 0, 0, .06);\n    }\n\n    .ms-sitem label {\n        font-size: 11px;\n        color: #64748b;\n        display: block;\n        margin-bottom: 4px;\n    }\n\n    .ms-track {\n        background: #f1f5f9;\n        border-radius: 99px;\n        height: 6px;\n        overflow: hidden;\n    }\n\n    .ms-fill {\n        height: 100%;\n        border-radius: 99px;\n        transition: width .8s ease;\n    }\n\n    .ms-scount {\n        font-size: 20px;\n        font-weight: 700;\n        color: #1a1f36;\n        margin-top: 4px;\n    }\n\n    .ms-twrap {\n        background: #fff;\n        border-radius: 12px;\n        padding: 16px;\n        box-shadow: 0 1px 4px rgba(0, 0, 0, .07);\n        margin-bottom: 16px;\n        overflow-x: auto;\n    }\n\n    .ms-tbl {\n        width: 100%;\n        border-collapse: collapse;\n        font-size: 13px;\n    }\n\n    .ms-tbl th {\n        text-align: left;\n        padding: 7px 10px;\n        background: #f8fafc;\n        color: #64748b;\n        font-weight: 600;\n        font-size: 11px;\n        text-transform: uppercase;\n        border-bottom: 1px solid #e2e8f0;\n    }\n\n    .ms-tbl td {\n        padding: 9px 10px;\n        border-bottom: 1px solid #f1f5f9;\n        color: #1a1f36;\n    }\n\n    .ms-tbl tr:last-child td {\n        border-bottom: none\n    }\n\n    .ms-badge {\n        display: inline-block;\n        padding: 2px 8px;\n        border-radius: 99px;\n        font-size: 11px;\n        font-weight: 600;\n    }\n\n    .ms-badge.o {\n        background: #fff7ed;\n        color: #c2410c\n    }\n\n    .ms-badge.r {\n        background: #fef2f2;\n        color: #dc2626\n    }\n\n    .ms-foot {\n        font-size: 11px;\n        color: #94a3b8;\n        text-align: right;\n    }\n\n    .ms-sk {\n        background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);\n        background-size: 200% 100%;\n        animation: msShim 1.4s infinite;\n        border-radius: 6px;\n        height: 30px;\n    }\n\n    @keyframes msShim {\n        0% {\n            background-position: 200% 0\n        }\n\n        100% {\n            background-position: -200% 0\n        }\n    }\n</style>\n\n<div class=\"ms-dash\">\n    <h2><span class=\"ms-dot\"></span> Maintenance Operations Dashboard <button class=\"ms-rbtn\" id=\"ms-rbtn\">&#x21bb;\n            Refresh</button></h2>\n    <div class=\"ms-cards\">\n        <div class=\"ms-card blue\" id=\"ms-c-active\">\n            <div class=\"ms-clabel\">Active Tickets</div>\n            <div class=\"ms-cvalue\" id=\"ms-active\">\n                <div class=\"ms-sk\"></div>\n            </div>\n            <div class=\"ms-csub\">Under Maintenance</div>\n        </div>\n        <div class=\"ms-card orange\" id=\"ms-c-cust\">\n            <div class=\"ms-clabel\">Pending Custody</div>\n            <div class=\"ms-cvalue\" id=\"ms-custody\">\n                <div class=\"ms-sk\"></div>\n            </div>\n            <div class=\"ms-csub\">Items still issued</div>\n        </div>\n        <div class=\"ms-card green\" id=\"ms-c-done\">\n            <div class=\"ms-clabel\">Completed This Month</div>\n            <div class=\"ms-cvalue\" id=\"ms-completed\">\n                <div class=\"ms-sk\"></div>\n            </div>\n            <div class=\"ms-csub\" id=\"ms-month\"></div>\n        </div>\n        <div class=\"ms-card purple\">\n            <div class=\"ms-clabel\">Overdue (72h+)</div>\n            <div class=\"ms-cvalue\" id=\"ms-overdue\">\n                <div class=\"ms-sk\"></div>\n            </div>\n            <div class=\"ms-csub\">No activity 3+ days</div>\n        </div>\n        <div class=\"ms-card red\" id=\"ms-c-wait\">\n            <div class=\"ms-clabel\">Waiting</div>\n            <div class=\"ms-cvalue\" id=\"ms-waiting\">\n                <div class=\"ms-sk\"></div>\n            </div>\n            <div class=\"ms-csub\">Awaiting assignment</div>\n        </div>\n    </div>\n    <div class=\"ms-stitle\">Ticket Status Breakdown</div>\n    <div class=\"ms-sgrid\" id=\"ms-sgrid\">\n        <div class=\"ms-sk\" style=\"height:70px\"></div>\n    </div>\n    <div class=\"ms-stitle\">Pending Custody Returns</div>\n    <div class=\"ms-twrap\">\n        <table class=\"ms-tbl\">\n            <thead>\n                <tr>\n                    <th>Record</th>\n                    <th>Order</th>\n                    <th>Status</th>\n                    <th>Expected Return</th>\n                </tr>\n            </thead>\n            <tbody id=\"ms-ctbody\">\n                <tr>\n                    <td colspan=\"4\">\n                        <div class=\"ms-sk\"></div>\n                    </td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n    <div class=\"ms-foot\" id=\"ms-ts\"></div>\n</div>\n\n<script>\n    (function () {\n        var SC = { 'Waiting': '#3b82f6', 'In Directing': '#8b5cf6', 'Under Maintenance': '#f97316', 'In Processing': '#eab308', 'Complete': '#22c55e', 'Paid': '#10b981' };\n\n        function q(id) { return root_element.querySelector('#' + id); }\n        function n(arr, k) { var m = (arr || []).find(function (r) { return r.status === k; }); return m ? (parseInt(m.cnt) || 0) : 0; }\n\n        function load() {\n            frappe.call({\n                method: 'maintenance_system.maintenance_system.api.get_dashboard_data',\n                callback: function (r) {\n                    if (!r || !r.message) return;\n                    var d = r.message, sc = d.status_counts || [];\n\n                    q('ms-active').textContent = n(sc, 'Under Maintenance');\n                    q('ms-waiting').textContent = n(sc, 'Waiting');\n                    q('ms-completed').textContent = d.completed_this_month || 0;\n                    q('ms-overdue').textContent = d.overdue_count || 0;\n                    q('ms-custody').textContent = (d.pending_custody || []).length;\n                    q('ms-month').textContent = d.month_name || '';\n\n                    q('ms-c-active').onclick = function () { frappe.set_route('List', 'Maintenance Order', { status: 'Under Maintenance' }); };\n                    q('ms-c-cust').onclick = function () { frappe.set_route('List', 'Technician Custody', { custody_status: 'Issued' }); };\n                    q('ms-c-done').onclick = function () { frappe.set_route('List', 'Maintenance Order', { status: 'Complete' }); };\n                    q('ms-c-wait').onclick = function () { frappe.set_route('List', 'Maintenance Order', { status: 'Waiting' }); };\n\n                    var total = sc.reduce(function (s, r) { return s + (parseInt(r.cnt) || 0); }, 0) || 1;\n                    var grid = q('ms-sgrid'); grid.innerHTML = '';\n                    Object.keys(SC).forEach(function (st) {\n                        var cnt = n(sc, st), pct = Math.round(cnt / total * 100);\n                        var el = document.createElement('div'); el.className = 'ms-sitem';\n                        el.innerHTML = '<label>' + st + '</label><div class=\"ms-track\"><div class=\"ms-fill\" style=\"width:' + pct + '%;background:' + SC[st] + '\"></div></div><div class=\"ms-scount\">' + cnt + '</div>';\n                        grid.appendChild(el);\n                    });\n\n                    var tb = q('ms-ctbody'), rows = d.pending_custody || [], today = new Date().toISOString().slice(0, 10);\n                    tb.innerHTML = rows.length ? rows.map(function (row) {\n                        var past = row.expected_return_date && row.expected_return_date < today;\n                        return '<tr><td><a href=\"/app/technician-custody/' + row.name + '\" target=\"_blank\">' + row.name + '</a></td>'\n                            + '<td>' + (row.maintenance_order || '—') + '</td>'\n                            + '<td><span class=\"ms-badge ' + (row.custody_status === 'Overdue' ? 'r' : 'o') + '\">' + row.custody_status + '</span></td>'\n                            + '<td style=\"' + (past ? 'color:#dc2626;font-weight:600' : '') + '\">' + (row.expected_return_date || '—') + '</td></tr>';\n                    }).join('') : '<tr><td colspan=\"4\" style=\"text-align:center;color:#94a3b8;padding:16px\">No pending custody returns</td></tr>';\n\n                    q('ms-ts').textContent = 'Last refreshed: ' + new Date().toLocaleTimeString();\n                }\n            });\n        }\n\n        q('ms-rbtn').addEventListener('click', load);\n        load();\n    })();\n</script>",
